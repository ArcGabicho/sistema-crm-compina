---
import Sparkles from "src/icons/Sparkles.astro";
import Heart from "src/icons/Heart.astro";
import Currency from "src/icons/Currency.astro";

const valores = [
  {
    title: "Deja tu huella",
    text: "Las prendas de vestir reflejan mucho la personalidad de las personas, ten la oportunidad de dejar tu propia huella en el mercado.",
    videoSrc: "/videos/vprom01.mp4",
    overlayText: "",
    icon: "sparkles"
  },
  {
    title: "Compromiso Contigo",
    text: "En COMPIPRO sabemos que las marcas de nuestros clientes tienen un valor muy especial y es por ello que los ayudamos a seguir creciendo.",
    videoSrc: "/videos/vprom02.mp4",
    overlayText: "¡Comprometidos!",
    icon: "heart"
  },
  {
    title: "Hábitos Ahorradores",
    text: "El ahorro es un gran recurso para poder cubrir gastos de imprevistos o realizar una futura inversión de la mejor manera.",
    videoSrc: "/videos/vprom03.mp4",
    overlayText: "",
    icon: "currency"
  }
];
---

<div class="max-w-7xl mx-auto px-4 text-center py-16">
  <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-12">
    POTENCIAMOS TU CRECIMIENTO
  </h2>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {valores.map((valor, index) => (
      <div class="group">
        <div class="bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:scale-105 mb-8">
          <!-- Video Container -->
          <div class="relative w-full h-48 overflow-hidden">
            {valor.overlayText && (
              <div class="absolute inset-0 bg-linear-to-br from-white/60 via-transparent to-white/60 bg-size-[20px_20px] flex items-center justify-center z-10"
                   style="background-image: repeating-linear-gradient(45deg, rgba(255,255,255,0.6), rgba(255,255,255,0.6) 10px, transparent 10px, transparent 20px);">
                <span class="text-white font-bold text-lg drop-shadow-lg">
                  {valor.overlayText}
                </span>
              </div>
            )}
            <video autoplay loop muted class="w-full h-full object-cover">
              <source src={valor.videoSrc} type="video/mp4" />
              Tu navegador no soporta videos.
            </video>
          </div>
          
          <!-- Card Body -->
          <div class="p-6">
            <div class="flex items-center justify-center mb-4">
              {valor.icon === "sparkles" && (
                <Sparkles />
              )}
              {valor.icon === "heart" && (
                <Heart />
              )}
              {valor.icon === "currency" && (
                <Currency />
              )}
            </div>
            <h5 class="font-bold text-lg md:text-xl text-gray-800 mb-3">
              {valor.title}
            </h5>
            <p class="text-gray-600 text-sm md:text-base leading-relaxed">
              {valor.text}
            </p>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>