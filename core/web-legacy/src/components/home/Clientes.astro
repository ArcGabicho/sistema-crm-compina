---
const clientes = [
  { src: 'images/imagencliente1.svg', alt: 'Cliente 1' },
  { src: 'images/imagencliente2.svg', alt: 'Cliente 2' },
  { src: 'images/imagencliente3.svg', alt: 'Cliente 3' },
  { src: 'images/imagencliente4.svg', alt: 'Cliente 4' },
  { src: 'images/imagencliente5.svg', alt: 'Cliente 5' },
  { src: 'images/imagencliente6.svg', alt: 'Cliente 6' },
  { src: 'images/imagencliente7.svg', alt: 'Cliente 7' },
  { src: 'images/imagencliente8.svg', alt: 'Cliente 8' },
];
---

<div class="max-w-7xl mx-auto px-4 text-center py-16">
  <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-12">
    NUESTROS CLIENTES
  </h2>
  
  <!-- Slider infinito -->
  <div class="relative overflow-hidden w-full h-24 md:h-32">
    <!-- Gradiente para fade effect -->
    <div class="absolute inset-0 z-10 pointer-events-none bg-linear-to-r from-white via-transparent to-white"></div>
    
    <!-- Contenedor del slider -->
    <div class="flex animate-scroll hover:pause-animation">
      <!-- Primera serie de logos -->
      {clientes.map((cliente, index) => (
        <div class="shrink-0 w-32 md:w-40 h-24 md:h-32 flex items-center justify-center mx-4 grayscale hover:grayscale-0 transition-all duration-500">
          <img 
            src={cliente.src} 
            alt={cliente.alt}
            class="max-w-full max-h-full object-contain opacity-60 hover:opacity-100 transition-opacity duration-500"
          />
        </div>
      ))}
      <!-- Segunda serie para loop infinito -->
      {clientes.map((cliente, index) => (
        <div class="shrink-0 w-32 md:w-40 h-24 md:h-32 flex items-center justify-center mx-4 grayscale hover:grayscale-0 transition-all duration-500">
          <img 
            src={cliente.src} 
            alt={cliente.alt}
            class="max-w-full max-h-full object-contain opacity-60 hover:opacity-100 transition-opacity duration-500"
          />
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  
  .animate-scroll {
    animation: scroll 20s linear infinite;
  }
  
  .pause-animation:hover {
    animation-play-state: paused;
  }
</style>