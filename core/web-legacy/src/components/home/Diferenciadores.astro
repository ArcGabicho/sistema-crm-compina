---
const diferenciadores = [
  {
    src: '/images/iconodeferenciador1.webp',
    alt: 'Merchandising',
    text: 'Más de 10 mil productos para <span class="font-bold">merchandising</span>'
  },
  {
    src: '/images/iconodeferenciador2.webp',
    alt: 'Pagos Seguros',
    text: 'Pagos y envíos <span class="font-bold">seguros</span>'
  },
  {
    src: '/images/iconodeferenciador3.webp',
    alt: 'Garantía',
    text: 'Proveedores de <span class="font-bold">garantía</span>'
  }
];
---

<!-- Sección de texto descriptivo -->
<div class="w-full bg-gray-500 flex justify-center items-center py-6 px-4 mt-5">
  <p class="text-white text-center max-w-4xl font-normal text-lg leading-relaxed">
    Todos nuestros artículos son personalizables para incluir el logotipo de tu empresa, tu eslogan, los nombres
    de tus empleados, clientes, socios u otra personalización.
  </p>
</div>

<!-- Sección de diferenciadores -->
<section class="max-w-7xl mx-auto px-4 py-16">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 justify-items-center">
    {diferenciadores.map((diferenciador) => (
      <div class="flex flex-col items-center text-center p-8 rounded-2xl gap-5 max-w-sm">
        <img 
          class="w-full max-w-48 h-auto" 
          src={diferenciador.src} 
          alt={diferenciador.alt} 
        />
        <p 
          class="text-gray-600 text-base md:text-lg max-w-48 leading-relaxed"
          set:html={diferenciador.text}
        >
        </p>
      </div>
    ))}
  </div>
</section>