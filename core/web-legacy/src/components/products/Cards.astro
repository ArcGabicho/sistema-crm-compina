---
const productGroups = [
  [
    {
      id: 1,
      name: "Altavoz Bambú",
      description: "Altavoz portátil ecológico con diseño moderno.",
      image: "/cardsProductos/producto1.jpg",
    },
    {
      id: 2,
      name: "Power Bank",
      description: "Batería externa de alta capacidad para dispositivos.",
      image: "/cardsProductos/producto2.jpg",
    },
    {
      id: 3,
      name: "Set de Escritorio",
      description: "Conjunto de portabolígrafos y organizador de escritorio.",
      image: "/cardsProductos/producto3.png",
    },
  ],
  [
    {
      id: 4,
      name: "Cuadernos con Diseño",
      description: "Cuadernos con diseño único y creativo.",
      image: "/cardsProductos/producto4.jpg",
    },
    {
      id: 5,
      name: "Pack para Estudiantes",
      description: "Pack completo de útiles escolares para estudiantes.",
      image: "/cardsProductos/producto5.jpg",
    },
    {
      id: 6,
      name: "Set de Gigantografias",
      description: "Conjunto de gigantografías para publicidad.",
      image: "/cardsProductos/producto6.png",
    },
  ],
];
---

<section class="py-20 px-4 bg-linear-to-br from-gray-50 to-gray-100">
  {productGroups.map((group) => (
    <div class="flex flex-col lg:flex-row justify-center items-stretch gap-8 max-w-8xl mx-auto mb-12 last:mb-0">
      {group.map((product) => (
        <div class="group flex-1 bg-white rounded-2xl border border-gray-200 shadow-lg hover:shadow-2xl text-center p-8 transition-all duration-500 ease-out hover:-translate-y-2 hover:scale-[1.02] backdrop-blur-sm relative overflow-hidden">
          <div class="absolute inset-0 bg-linear-to-br from-orange-50/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10">
            <div class="w-56 h-56 mx-auto mb-6 rounded-xl overflow-hidden shadow-md group-hover:shadow-lg transition-shadow duration-300">
              <img 
                src={product.image} 
                alt={`Producto ${product.id}`} 
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
              />
            </div>
            <h3 class="mb-3 text-2xl font-bold text-gray-800 group-hover:text-orange-600 transition-colors duration-300">
              {product.name}
            </h3>
            <p class="text-gray-600 mb-6 text-base leading-relaxed px-2">
              {product.description}
            </p>
            <button class="bg-linear-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white font-semibold py-3 px-8 rounded-full shadow-md hover:shadow-lg transform transition-all duration-300 hover:-translate-y-1 focus:outline-none focus:ring-4 focus:ring-orange-300">
              <a href="https://wa.me/973644878" target="_blank" class="text-white no-underline flex items-center gap-2">
                <span>💬</span>
                Cotizar Ahora
              </a>
            </button>
          </div>
        </div>
      ))}
    </div>
  ))}
</section>