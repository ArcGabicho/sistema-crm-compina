---
const catalogo = 'https://compipro.net/documentos/catalogo-compipro/Catalogo_Compipro.pdf'
---

<section class="flex flex-col md:flex-row items-center justify-center p-4 md:p-16 bg-gray-100 text-center">
    <div class="flex-none w-full md:w-1/2 flex flex-col items-center md:items-start text-center md:text-left max-w-lg mx-auto mb-8 md:mb-0">
        <span class="bg-orange-500 text-white py-2 px-4 rounded-full font-bold inline-block mb-4">
            30% de descuento
        </span>
        <h1 class="text-4xl md:text-5xl mb-4 leading-tight text-center md:text-left">
            Articulos Importados<br>Get it ordered
        </h1>
        <p class="text-gray-600 mb-8 text-lg text-center md:text-left">
            Save time, skip the lines. We've got you covered.
        </p>
        <button class="bg-orange-500 hover:bg-orange-700 text-white border-none py-2 px-4 text-lg rounded-lg cursor-pointer transition-colors duration-300 self-center md:self-start">
            <a href={catalogo} target="_blank" rel="noopener noreferrer" class="text-white no-underline">
                Catálogo
            </a>
        </button>
    </div>
    <div class="flex-none w-full md:w-1/2 flex justify-center items-center">
        <img src="/images/HeroProductos.png" alt="Corporate Gifts Collection" class="max-w-full md:max-w-full w-4/5 md:w-full h-auto">
    </div>
</section>