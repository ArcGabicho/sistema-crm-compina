---
// Array local para desarrollo - API caída
const categorias = [
  {
    id: "textiles",
    nombre: "Textiles",
    descripcion: "Camisetas, polos, sudaderas y más prendas personalizadas",
    portada: "/images/textiles-portada.jpg"
  },
  {
    id: "promocionales",
    nombre: "Promocionales",
    descripcion: "Artículos promocionales para eventos y campañas",
    portada: "/images/promocionales-portada.jpg"
  },
  {
    id: "oficina",
    nombre: "Oficina",
    descripcion: "Artículos de oficina personalizados y corporativos",
    portada: "/images/oficina-portada.jpg"
  },
  {
    id: "tecnologicos",
    nombre: "Tecnológicos",
    descripcion: "Dispositivos y accesorios tecnológicos personalizados",
    portada: "/images/tecnologicos-portada.jpg"
  },
  {
    id: "bolsas-empaques",
    nombre: "Bolsas y Empaques",
    descripcion: "Bolsas ecológicas, mochilas y soluciones de empaque",
    portada: "/images/bolsas-portada.jpg"
  },
  {
    id: "premium",
    nombre: "Premium",
    descripcion: "Productos de alta calidad y acabados especiales",
    portada: "/images/premium-portada.jpg"
  }
];

// Código comentado para cuando la API esté funcionando:
/*
const apiUrl = "https://go-compipro-api-production.up.railway.app/api/data";
try {
  const response = await fetch(apiUrl);
  categorias = await response.json();
} catch (error) {
  console.error("Error fetching categories:", error);
}
*/
---

<section class="max-w-7xl mx-auto py-16 px-4">
  <div class="text-center mb-12">
    <h1 class="text-4xl font-bold bg-linear-to-r from-gray-800 to-gray-600 bg-clip-text text-transparent mb-3">
      Nuestros Productos
    </h1>
    <div class="w-16 h-0.5 bg-linear-to-r from-yellow-400 to-orange-500 mx-auto rounded-full"></div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {categorias.map((categoria, index) => (
      <div 
        class="group bg-white/95 backdrop-blur-sm rounded-2xl p-5 shadow-md hover:shadow-xl transition-all duration-500 ease-out hover:-translate-y-1 hover:scale-[1.02] border border-gray-100 hover:border-orange-200 overflow-hidden animate-fade-in-up"
        style={`animation-delay: ${index * 80}ms`}
      >
        <div class="absolute inset-0 bg-linear-to-br from-orange-50/40 to-yellow-50/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl"></div>
        
        <div class="relative z-10">
          <div class="w-full h-36 mb-4 rounded-xl overflow-hidden bg-linear-to-br from-gray-100 to-gray-200 group-hover:shadow-md transition-shadow duration-300">
            <div class="absolute inset-0 bg-linear-to-r from-transparent via-white/25 to-transparent -skew-x-12 -translate-x-full group-hover:translate-x-full transition-transform duration-1000 z-10"></div>
            <img 
              src={categoria.portada} 
              alt={categoria.nombre} 
              class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105 group-hover:brightness-110" 
            />
          </div>
          
          <div class="space-y-3">
            <h3 class="text-lg font-bold text-gray-800 group-hover:text-orange-600 transition-colors duration-300 leading-tight">
              {categoria.nombre}
            </h3>
            <p class="text-gray-600 text-sm leading-relaxed line-clamp-2">
              {categoria.descripcion}
            </p>
            
            <button 
              class="w-full py-2.5 bg-linear-to-r from-orange-500 to-yellow-500 hover:from-orange-600 hover:to-yellow-600 text-white font-semibold text-sm rounded-lg transition-all duration-300 hover:shadow-lg transform hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-orange-300/50 relative overflow-hidden group"
              onclick={`window.location.href='/${categoria.id}'`}
            >
              <span class="relative z-10 flex items-center justify-center gap-1.5">
                <span class="text-xs">⚡</span>
                Solicitar
                <span class="text-xs group-hover:translate-x-1 transition-transform duration-300">→</span>
              </span>
              <div class="absolute inset-0 bg-white/10 -translate-x-full group-hover:translate-x-full transition-transform duration-500 skew-x-12"></div>
            </button>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
@keyframes fade-in-up {
  from {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.animate-fade-in-up {
  animation: fade-in-up 0.6s ease-out forwards;
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
</style>