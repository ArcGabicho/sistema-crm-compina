---
import Facebook from "src/icons/Facebook.astro";
import Instagram from "src/icons/Instagram.astro";
import Linkedin from "src/icons/Linkedin.astro";
import Pinterest from "src/icons/Pinterest.astro";

// Footer data structure
const lineasPrincipales = [
  { name: "Línea Madera", href: "#" },
  { name: "Publicidad Exterior", href: "#" },
  { name: "Uniformes Corporativos", href: "#" },
  { name: "Accesorios Tecnológicos", href: "#" }
];

const contactoInfo = [
  { text: "contacto@merchmaster.com", href: "mailto:contacto@merchmaster.com" },
  { text: "+51 123 456 789", href: "tel:+51123456789" },
  { text: "Av. Principal 123, Lima", href: "#" }
];
---

<footer class="bg-black text-white py-16">
  <div class="max-w-7xl mx-auto px-4">
    <!-- Logo y botón -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-8 text-center">
      <img 
        src="/images/logofooter.webp" 
        alt="Logo Compipro" 
        class="max-w-60 w-full h-auto mb-4 md:mb-0"
      />
      <a href="#" class="bg-white text-black font-bold px-8 py-3 rounded-full hover:bg-gray-100 transition-colors duration-300">
        Sistema CRM
      </a>
    </div>

    <!-- Línea divisoria -->
    <hr class="border-white border-t mb-8"/>

    <!-- Sección de widgets -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 text-center md:text-left">
      <!-- Widget 1: Sobre Compipro -->
      <div class="md:col-span-1">
        <h5 class="font-bold text-lg mb-4">Sobre Compipro</h5>
        <div class="text-sm space-y-2">
          <p>© 2025 COMPIPRO S.A.C. - Soluciones en artículos publicitarios y merchandising empresarial. Creatividad, calidad y puntualidad para potenciar tu marca.</p>
          <p>Visítanos en <a href="https://compipro.com" target="_blank" class="text-blue-400 underline hover:text-blue-300">compipro.com</a></p>
          <p>Contacto: ventas@compipro.net</p>
        </div>
        <!-- Iconos sociales móvil -->
        <div class="flex justify-center md:justify-start gap-4 mt-4">
          <!-- Facebook -->
          <a href="#" class="text-white hover:text-orange-400 transition-colors duration-300">
            <Facebook />
          </a>
          <!-- Instagram -->
          <a href="#" class="text-white hover:text-orange-400 transition-colors duration-300">
            <Instagram />
          </a>
          <!-- LinkedIn -->
          <a href="#" class="text-white hover:text-orange-400 transition-colors duration-300">
            <Linkedin />
          </a>
          <!-- Pinterest -->
          <a href="#" class="text-white hover:text-orange-400 transition-colors duration-300">
            <Pinterest />
          </a>
        </div>
      </div>

      <!-- Widget 2: Líneas Principales -->
      <div class="hidden md:block">
        <h5 class="font-bold text-lg mb-4">Líneas Principales</h5>
        <div class="text-sm space-y-2">
          {lineasPrincipales.map((linea) => (
            <a 
              href={linea.href} 
              class="block text-white hover:text-blue-400 hover:underline transition-colors duration-200"
            >
              {linea.name}
            </a>
          ))}
        </div>
      </div>

      <!-- Widget 3: Contacto -->
      <div class="hidden md:block">
        <h5 class="font-bold text-lg mb-4">Contacto</h5>
        <div class="text-sm space-y-2">
          {contactoInfo.map((info) => (
            <a 
              href={info.href} 
              class="block text-white hover:text-blue-400 hover:underline transition-colors duration-200"
            >
              {info.text}
            </a>
          ))}
        </div>
      </div>

      <!-- Widget 4: Redes Sociales -->
      <div class="hidden md:block">
        <h5 class="font-bold text-lg mb-4">Redes Sociales</h5>
        <div class="flex gap-4">
          <!-- Facebook -->
          <a href="#" class="text-white hover:text-orange-400 transition-colors duration-300">
            <Facebook />
          </a>
          <!-- Instagram -->
          <a href="#" class="text-white hover:text-orange-400 transition-colors duration-300">
            <Instagram />
          </a>
          <!-- LinkedIn -->
          <a href="#" class="text-white hover:text-orange-400 transition-colors duration-300">
            <Linkedin />
          </a>
          <!-- Pinterest -->
          <a href="#" class="text-white hover:text-orange-400 transition-colors duration-300">
            <Pinterest />
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>